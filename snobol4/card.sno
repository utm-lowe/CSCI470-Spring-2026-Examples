* rules for the card matching
        DIGITS = '0123456789'
        FACES  = 'JQKA'
        SUITS  = 'HSCD'
        NUMBER = BREAK(DIGITS) SPAN(DIGITS)
        FACE   = ANY(FACES)
        SUIT   = ANY(SUITS)

LOOP    OUTPUT = "Enter a card."
        CARD = INPUT
        CARD NUMBER . VAL SUIT :S(DONE)
        CARD FACE SUIT         :F(LOOP)
        VAL = 10
DONE    OUTPUT = "Blackjack value " VAL :(LOOP)
END