* Demonstrate pattern replacement
    msg = "Hello, name_field, nice to meet you."
    OUTPUT = "What is your name?"
    name = INPUT
    msg "name_field" = name
    OUTPUT = msg

* We can replace digits in an integer
    x = 155526
    x "5" = 0
    OUTPUT = x

* We can do a "replace all"
L1 x "5" = 0                           :s(L1)
    OUTPUT = x
END 