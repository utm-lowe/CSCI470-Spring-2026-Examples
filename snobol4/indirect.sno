        x = 1
        y = 2
        z = 3
        OUTPUT = .x

LOOP    OUTPUT = "I have x, y, and z. Which do you want to change?"
        var = INPUT 
        var POS(0) ('x' | 'y' | 'z') RPOS(0)    :F(LOOP)
        OUTPUT = "What is your value? "
        $var = INPUT
        OUTPUT = "x: " x " y: " y " z: " z      :(LOOP)
END